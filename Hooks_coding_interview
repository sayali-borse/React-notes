1️⃣ Counter using useState
Question

Create a counter with Increment and Decrement buttons.

Example
import React, { useState } from "react";

function Counter(){

 const [count,setCount] = useState(0)

 return(
  <div>
   <h1>{count}</h1>

   <button onClick={()=>setCount(count+1)}>
    Increment
   </button>

   <button onClick={()=>setCount(count-1)}>
    Decrement
   </button>

  </div>
 )
}

export default Counter
