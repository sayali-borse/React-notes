 )
}
6️⃣ Expensive Calculation using useMemo
Question

Optimize heavy calculation.

import React, { useMemo, useState } from "react";

function Expensive(){

 const [count,setCount] = useState(0)

 const calculation = useMemo(()=>{
   console.log("Calculating...")
   return count*2
 },[count])

 return(
  <>
   <h1>{calculation}</h1>
   <button onClick={()=>setCount(count+1)}>
    Increase
   </button>
  </>
 )
}
Interview Question

Why use useMemo?

Answer: To avoid unnecessary calculations.

